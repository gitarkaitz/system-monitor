<Window x:Class="SystemMonitor.UI.AlertNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alerta" Height="150" Width="300"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <StackPanel Margin="15">
        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="0,0,0,15" FontWeight="Bold" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cerrar" Width="80" Margin="0,0,10,0" Click="OnCloseClick" />
            <Button Content="Aceptar" Width="80" Click="OnAcceptClick" />
        </StackPanel>
    </StackPanel>
</Window>
